# Multi-Agent 代理名称配置
# 安装后复制此文件为 .env 并修改对应的值即可自定义代理名称

# 总调度
MASTER_NAME=总调度

# 主程
LEAD_PROGRAMMER_NAME=主程

# 策划
PLANNER_NAME=策划

# 美术
ARTIST_NAME=美术

# 开发
BUILD_NAME=开发者

# 规划
PLAN_NAME=规划师

# 测试
TEST_WRITER_NAME=测试员

# 审查
CODE_REVIEWER_NAME=审查员

# 安全
SECURITY_AUDITOR_NAME=安全审计

# 文档
DOCS_WRITER_NAME=文档师

# 性能
PERFORMANCE_OPTIMIZER_NAME=性能优化
