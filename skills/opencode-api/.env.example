# OpenCode API 配置

# OpenCode 服务器地址 (默认为 http://127.0.0.1:9091)
OPENCODE_SERVER_URL=http://127.0.0.1:9091

# 使用的模型 (默认为 opencode/mimo-v2-omni-free)
OPENCODE_MODEL=opencode/mimo-v2-omni-free

# OpenCode 服务器密码 (必填)
OPENCODE_SERVER_PASSWORD=your-server-password-here

# opencode-cli.exe 路径 (如果脚本需要直接运行 CLI)
OPENCODE_CLI_PATH=D:\Users\ay\AppData\Local\OpenCode\opencode-cli.exe
